---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="container mx-auto px-6 md:px-12 lg:px-20">
			<div class="min-w-full flex flex-col items-start justify-start pb-12 md:pb-20 pt-12 md:pt-20">
				<div class="w-full flex flex-row items-center justify-between">
					<p class="font-display text-sm font-bold text-custom-dark">&#9737; <span class="opacity-30">\</span> &#9783; <span class="opacity-30">\</span> &#9826;</p>
					<p class="text-end font-display text-xs md:text-sm font-bold text-custom-dark">	<span class="opacity-30">&#172;</span> BLOG <span class="opacity-30">\</span> PL </p>
				</div>
			</div>
		</main>
		<div class="-mb-px separator">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 25" version="1.1" xmlns:xlink="http://www.w3.org/1999/xlink" transform="matrix(1,0,0,-1,0,0)"><path d="M 0 0 v 1 l 500 24 l 500 -24 V 0 H 0 z" fill="#383838"></path></svg>
		</div>
		<section class="h-fit pb-1 bg-custom-dark mt-0 pt-3">
			<div class="container mx-auto px-6 md:px-12 lg:px-20">
				<div class="flex items-center gap-2 md:gap-3 mb-6 md:mb-8">
					<h2 class="font-display text-xl md:text-3xl text-custom-light uppercase"><span class="opacity-30">&gt;</span> ALL BLOG POSTS</h2>
					<div style="height: 2px" class="flex-grow bg-custom-light opacity-30"/>
					<span class="font-display font-medium text-sm md:text-lg text-custom-light opacity-75">&#9998; \ &#9783;</span>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-5 gap-4 md:gap-8 text-custom-light my-6 md:my-8">
					<div class="md:col-span-2 flex flex-col">
						<div class="md:sticky md:top-1/3 -mb-3 flex flex-col gap-4 md:gap-6">
							<p class="font-body text-base md:text-lg text-justify">Explore all blog posts covering programming, system design, DevSecOps, and cutting-edge technologies. Each article is crafted to inform, inspire, and share practical insights from real-world experience. <span class="opacity-30">\R\N</span></p>
							<div class="flex flex-row w-full items-center gap-4">
								<a href="/" class="font-display text-sm md:text-base text-custom-light transition duration-300 ease-in-out hover:opacity-30">BACK TO HOME <span class="opacity-30">&#172;</span></a>
								<div style="height: 2px" class="flex-grow bg-custom-light opacity-30"/>
							</div>
						</div>
					</div>
					<div class="md:col-span-3 flex flex-col items-stretch gap-2 border-opacity-30 border-l-0 md:border-l-2 border-custom-light md:pl-4 lg:pl-6">
						{posts.map((post) => (
							<a href={`/blog/${post.slug}/`} class="block group">
								<div class="flex flex-row items-start gap-3 md:gap-4 py-3 transition duration-300 ease-in-out hover:bg-custom-light hover:bg-opacity-10 -mx-3 px-3">
									<div class="flex-shrink-0 w-20 md:w-28 lg:w-32 h-14 md:h-16 lg:h-20 bg-custom-dark bg-opacity-30 overflow-hidden" style={`clip-path: polygon(10% 0%, 100% 0%, 90% 100%, 0% 100%);`}>
										{post.data.heroImage && (
											<img src={post.data.heroImage} alt="" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition duration-300" />
										)}
									</div>
									<div class="flex flex-col flex-grow">
										<h4 class="font-display text-base md:text-xl text-custom-light group-hover:text-white transition duration-300">{post.data.title}</h4>
										<p class="font-body text-xs md:text-sm text-custom-light opacity-70 mt-0 md:mt-1">{post.data.description}</p>
										<p class="font-display text-xs md:text-sm text-custom-light opacity-50 mt-1 md:mt-2">
											<FormattedDate date={post.data.pubDate} />
											<span class="opacity-30"> \ </span>
											{post.data.minRead} min read
										</p>
									</div>
								</div>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>
		<div class="-mb-px separator">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 620 25">
				<path d="M 0 0 v 20 L 310 5 l 310 20 V 0 H 0 z" fill="#383838"/>
			</svg>
		</div>
		<Footer />
	</body>
</html>
