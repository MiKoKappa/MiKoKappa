      <div class="container mx-auto px-6 md:px-12 lg:px-20">
        <div class="flex items-center gap-2 md:gap-3">
          <h2 class="font-display text-xl md:text-3xl text-custom-light">
            <span class="opacity-30">&gt;</span> WHAT'S IN MY TOOLBOX
          </h2>
          <div style="height: 2px" class="flex-grow bg-custom-light opacity-30">
          </div>
          <span
            class="font-display text-custom-light text-sm md:text-xl opacity-30"
            >&#10004; \ &#9874;</span
          >
        </div>
        <div
