---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import BlogPostCard from "../components/BlogPostCard.astro";
import { getCollection } from "astro:content";
const today = new Date();
const allPosts = await getCollection("blog");
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`${SITE_TITLE} - Main Page`}
      description={SITE_DESCRIPTION}
    />
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/0.7.2/p5.min.js"
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/0.7.2/addons/p5.dom.min.js"
    ></script>
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/0.7.2/addons/p5.sound.min.js"
    ></script>
  </head>
  <body>
    <Header />
    <main class="container mx-auto px-6 md:px-12 lg:px-20">
      <div
        class="min-w-full flex flex-col items-start justify-start pb-12 md:pb-20 pt-12 md:pt-20"
      >
        <div class="w-full flex flex-row items-center justify-between">
          <p class="font-display text-sm font-bold text-custom-dark">
            &#9737; <span class="opacity-30">\</span> &#9783; <span
              class="opacity-30">\</span
            > &#9826;
          </p>
          <p
            class="text-end font-display text-xs md:text-sm font-bold text-custom-dark"
          >
            <span class="opacity-30">&#172;</span>
            {today.getFullYear()}
            <span class="opacity-30">\</span> WAW <span class="opacity-30"
              >\</span
            > PL
          </p>
        </div>
        <div id="p5-canvas" class="w-full h-48 md:h-64 lg:h-96 my-4 md:my-6">
          <script is:inline src="/sketch.js"></script>
        </div>
        <div
          class="flex flex-row items-center justify-start w-full mt-4 md:mt-6"
        >
          <div class="text-start">
            <p
              class="text-custom-dark font-display text-sm md:text-base uppercase font-semibold leading-relaxed"
            >
              &gt; R&D EXPERT AT ORANGE INNOVATION POLAND. <span
                class="opacity-30">\R\N</span
              ><br />
              DEVOTED TO INTEGRATION OF NEW CUTTING<span class="opacity-30"
                >-</span
              >EDGE TECHNOLOGIES TO CREATE INNOVATIVE SOLUTIONS FOR THE <span
                class="opacity-30">\</span
              >
              <span class="typewriter thick"></span>
              <span class="opacity-30">\</span>.
            </p>
            <ul
              class="flex flex-col text-custom-dark font-display font-semibold gap-2 md:gap-3 mt-3 md:mt-4 text-sm md:text-base"
            >
              <a href="/blog">
                <li
                  class="cursor-pointer transition duration-300 ease-in-out hover:opacity-40 inline-block w-fit"
                >
                  <span class="opacity-30">-</span>
                  <span>SEE THE BLOG POSTS</span>
                </li>
              </a>
              <a href="/about">
                <li
                  class="cursor-pointer transition duration-300 ease-in-out hover:opacity-40 inline-block w-fit"
                >
                  <span class="opacity-30">-</span>
                  <span
                    >MY ROADMAP <span class="opacity-30">/</span> ABOUT ME</span
                  >
                </li>
              </a>
              <a href="/about">
                <li
                  class="cursor-pointer transition duration-300 ease-in-out hover:opacity-40 inline-block w-fit"
                >
                  <span class="opacity-30">-</span>
                  <span>GET IN TOUCH</span>
                </li>
              </a>
            </ul>
          </div>
        </div>
        <div class="text-neutral-500 w-full text-center mt-8 md:mt-16">
          <a aria-label="Scroll to blog" href="#blog-section">
            <svg
              class="mx-auto w-6 h-6 md:w-8 md:h-8"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M17.5001 8.08582L12.0002 13.5858L6.50015 8.08582L5.08594 9.50003L12.0002 16.4142L18.9144 9.50003L17.5001 8.08582Z"
                fill="currentColor"></path>
            </svg>
          </a>
        </div>
      </div>
    </main>
    <div class="-mb-px separator">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1000 25"
        version="1.1"
        xmlns:xlink="http://www.w3.org/1999/xlink"
        transform="matrix(1,0,0,-1,0,0)"
        ><path d="M 0 0 v 1 l 500 24 l 500 -24 V 0 H 0 z" fill="#383838"
        ></path></svg
      >
    </div>
    <section class="h-fit pb-1 bg-custom-dark mt-0 pt-3" id="blog-section">
      <div class="container mx-auto px-6 md:px-12 lg:px-20">
        <div class="flex items-center gap-2 md:gap-3">
          <h2 class="font-display text-xl md:text-3xl text-custom-light">
            <span class="opacity-30">&gt;</span> LATEST BLOG POSTS
          </h2>
          <div style="height: 2px" class="flex-grow bg-custom-light opacity-30">
          </div>
          <span
            class="font-display text-custom-light text-sm md:text-xl opacity-30"
            >&#9998; \ &#9783;</span
          >
        </div>
        <div
          class="grid grid-cols-1 md:grid-cols-5 gap-4 md:gap-8 text-custom-light my-6 md:my-8"
        >
          <div class="md:col-span-2 flex flex-col">
            <div
              class="md:sticky md:top-1/3 -mb-3 flex flex-col gap-4 md:gap-6"
            >
              <p class="font-body text-base md:text-lg text-justify">
                Stay up to date with the latest insights, experiments, and deep
                dives from the world of programming, system design and
                DevSecOps. <span class="opacity-30">\R\N</span>
              </p>
              <div class="flex flex-row w-full items-center gap-4">
                <a
                  href="/blog"
                  class="font-display text-sm md:text-base text-custom-light transition duration-300 ease-in-out hover:opacity-30"
                  >SEE MORE <span class="opacity-30">&#172;</span></a
                >
                <div
                  style="height: 2px"
                  class="flex-grow bg-custom-light opacity-30"
                >
                </div>
              </div>
            </div>
          </div>
          <div
            class="md:col-span-3 flex flex-col items-stretch gap-2 border-opacity-30 border-l-0 md:border-l-2 border-custom-light md:pl-4 lg:pl-6"
          >
            {
              Object.values(allPosts)
                .sort(
                  (a, b) =>
                    new Date(b.data.pubDate).getTime() -
                    new Date(a.data.pubDate).getTime(),
                )
                .slice(0, 5)
                .map((post) => (
                  <BlogPostCard
                    isMain={true}
                    post={post}
                    isMain={true}
                    url={`/${post.collection}/${post.slug}`}
                  />
                ))
            }
            <div class="w-full flex flex-row justify-center items-center">
              <a href="/blog">&#9900; &#9900; &#9900;</a>
            </div>
          </div>
        </div>
      </div>
    </section>
    <div class="-mb-px separator">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1000 25"
        version="1.1"
        xmlns:xlink="http://www.w3.org/1999/xlink"
        transform="matrix(1,0,0,1,0,0)"
        ><path d="M 0 0 v 1 l 500 24 l 500 -24 V 0 H 0 z" fill="#383838"
        ></path></svg
      >
    </div>
    <section
      class="mt-12 md:mt-20 mb-12 md:mb-20 pt-4 md:pt-6"
      id="about-section"
    >
      <div class="container mx-auto px-6 md:px-12 lg:px-20">
        <div class="flex items-center gap-2 md:gap-3">
          <div style="height: 2px" class="flex-grow bg-custom-dark opacity-30">
          </div>
          <h2 class="font-display text-xl md:text-3xl text-custom-dark">
            <span class="opacity-30">&lt;</span> ABOUT ME <span
              class="opacity-30">&gt;</span
            >
          </h2>
          <div style="height: 2px" class="flex-grow bg-custom-dark opacity-30">
          </div>
        </div>
        <div
          class="grid grid-cols-1 md:grid-cols-5 gap-6 md:gap-8 text-custom-dark mt-8 md:my-16"
        >
          <div class="md:col-span-3 flex flex-col justify-center">
            <div class="flex flex-col gap-4 md:gap-6">
              <h3 class="font-display text-xl md:text-3xl text-custom-dark">
                <span class="opacity-30">&gt;</span> Driven by curiosity. Refined
                by experience. <span class="opacity-30">\R\N</span><br />
              </h3>
              <p class="font-body text-base md:text-lg text-justify">
                I'm a Research & Development Expert with a passion for turning
                complex ideas into meaningful solutions. <br /><br />My work
                bridges the gap between innovation and implementation — shaping
                systems and services that are not only cutting-edge but
                intuitive and state-of-the-art. I specialize in designing and
                delivering solutions that meet today's needs while anticipating
                tomorrow's challenges. I value clarity, precision, and purpose —
                whether I'm exploring new technologies, leading a team of
                developers, or writing a single line of code.
              </p>
              <p class="text-base md:text-lg font-display">
                Always learning. Always building. Always a step ahead. <span
                  class="opacity-30">\R\N</span
                >
              </p>
              <div class="flex flex-row w-full items-center gap-4">
                <a
                  href="/about"
                  class="font-display font-medium text-sm md:text-base text-custom-dark transition duration-300 ease-in-out hover:opacity-30"
                  >GET IN TOUCH <span class="opacity-30">&#172;</span></a
                >
                <div
                  style="height: 2px"
                  class="flex-grow bg-custom-light opacity-30"
                >
                </div>
              </div>
            </div>
          </div>
          <div
            class="md:col-span-2 flex flex-col items-stretch gap-2 border-opacity-30 border-l-0 md:border-l-2 border-custom-light md:pl-4 lg:pl-6"
          >
            <div class="w-full md:w-3/4 lg:w-full bg-custom-dark bg-opacity-30">
              <img
                class="w-full max-w-[280px] md:max-w-[350px] lg:max-w-none"
                src="blog_portrait-sorted.webp"
              />
            </div>
          </div>
        </div>
      </div>
    </section>
    <div class="-mb-px separator">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1000 25"
        version="1.1"
        xmlns:xlink="http://www.w3.org/1999/xlink"
        transform="matrix(1,0,0,-1,0,0)"
        ><path d="M 0 0 v 1 l 500 24 l 500 -24 V 0 H 0 z" fill="#383838"
        ></path></svg
      >
    </div>
