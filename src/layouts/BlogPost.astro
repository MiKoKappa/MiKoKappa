---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
let backgroundUrl = `url()`
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main class="pt-20">
			<article>
				<div class="container px-6 mx-auto mb-6 uppercase font-display font-medium text-custom-dark">
					<a href="/blog">blog</a>
					<span class="opacity-70">&gt; {title}
					</span>

				</div>
				
				<div class="-mb-px separator">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 25" version="1.1" xmlns:xlink="http://www.w3.org/1999/xlink" transform="matrix(1,0,0,-1,0,0)"><path d="M 0 0 v 1 l 500 24 l 500 -24 V 0 H 0 z" fill="#383838"></path></svg>
				</div>
				<section class="h-fit pb-1 bg-custom-dark text-custom-light font-body text-lg text-justify mt-0 pt-3" id="blog-section">
					<div class="flex flex-row justify-center items-center container px-6 mx-auto">
						<div class="grayscale mb-14 w-full h-60 translate-x-10 bg-custom-dark" style={`background-image: url(${heroImage}); background-size: cover; background-repeat: no-repeat; clip-path: polygon(10% 0%, 100% 0%, 90% 100%, 0% 100%);`}>
						</div>
					</div>
						<div class="container mx-auto px-6">
							<slot />
						</div>
					</div>
				</section>
		<div class="-mb-px separator">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 620 25">
				<path d="M 0 0 v 20 L 310 5 l 310 20 V 0 H 0 z" fill="#383838"/>
			</svg>
		</div>
	</body>
</html>

<style is:global>
	#blog-section h1 {
		font-family: 'Chakra Petch', system-ui, sans-serif;
		font-size: 2.5rem;
		font-weight: 600;
		color: #fff;
		margin-top: 2rem;
		margin-bottom: 1rem;
	}
	#blog-section h2 {
		font-family: 'Chakra Petch', system-ui, sans-serif;
		font-size: 1.875rem;
		font-weight: 600;
		color: #fff;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		border-bottom: 1px solid rgba(205, 202, 197, 0.3);
		padding-bottom: 0.5rem;
	}
	#blog-section h3 {
		font-family: 'Chakra Petch', system-ui, sans-serif;
		font-size: 1.5rem;
		font-weight: 500;
		color: #cdcac5;
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}
	#blog-section h4, #blog-section h5, #blog-section h6 {
		font-family: 'Chakra Petch', system-ui, sans-serif;
		font-weight: 500;
		color: #cdcac5;
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
	}
	#blog-section p {
		margin-bottom: 1.25rem;
		line-height: 1.8;
	}
	#blog-section ul, #blog-section ol {
		margin-bottom: 1.25rem;
		padding-left: 1.5rem;
	}
	#blog-section li {
		margin-bottom: 0.5rem;
		line-height: 1.6;
	}
	#blog-section a {
		color: #cdcac5;
		text-decoration: underline;
		text-underline-offset: 3px;
		transition: opacity 0.3s ease;
	}
	#blog-section a:hover {
		opacity: 0.7;
	}
	#blog-section strong {
		color: #fff;
		font-weight: 600;
	}
	#blog-section em {
		color: #999;
		font-style: italic;
	}
	#blog-section hr {
		border: none;
		height: 1px;
		background: rgba(205, 202, 197, 0.3);
		margin: 2rem 0;
	}
	#blog-section blockquote {
		border-left: 3px solid rgba(205, 202, 197, 0.5);
		padding-left: 1rem;
		margin: 1.5rem 0;
		font-style: italic;
		opacity: 0.8;
	}
	#blog-section code {
		background: rgba(0, 0, 0, 0.3);
		padding: 0.125rem 0.375rem;
		border-radius: 0.25rem;
		font-family: monospace;
		font-size: 0.875em;
	}
	#blog-section pre {
		background: rgba(0, 0, 0, 0.3);
		padding: 1rem;
		border-radius: 0.5rem;
		overflow-x: auto;
		margin-bottom: 1.25rem;
	}
	#blog-section pre code {
		background: none;
		padding: 0;
	}
</style>
